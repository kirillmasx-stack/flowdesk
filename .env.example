# ── FlowDesk — Environment Variables ─────────────────────────
# On Railway: set these in Project → Variables tab

# PostgreSQL — Railway sets this automatically when you add PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-char-string

# App URL — set after Railway gives you a domain
CLIENT_URL=https://your-app.up.railway.app

# Node environment
NODE_ENV=production

# Telegram Bot (set later via app UI, or here)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# Keitaro (optional, can set via app UI)
KEITARO_URL=
KEITARO_API_KEY=
